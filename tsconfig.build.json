{
  "compilerOptions": {
    "noEmit": false,
    "outDir": "dist",
    "rootDir": ".",

    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",

    "declaration": true,
    "emitDeclarationOnly": false,
    "declarationMap": false,
    "sourceMap": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": ["src/**/*.ts", "bin/**/*.ts"],
  "exclude": ["dist", "node_modules", "tests/**"]
}